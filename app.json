{
  "expo": {
    "name": "HR Dock",
    "slug": "hr-dock-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "scheme": "hrdock",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F1829"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.hrdock.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F1829"
      },
      "package": "com.hrdock.mobile",
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-secure-store",
      "expo-router",
      "expo-font",
      "expo-notifications"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ed462a1f-c86c-4fb0-b16c-80bfafa38691"
      }
    }
  }
}
